# .env.template for Medical Report Digitization App
# Rename to .env and fill in the values to enable Google Cloud features

# OCR Engine: 'tesseract' or 'google_vision'
OCR_ENGINE=tesseract

# Storage Engine: 'sqlite' or 'bigquery'
STORAGE_ENGINE=sqlite

# Google Cloud Project Details
# GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json
# GCP_PROJECT_ID=your-project-id
# BIGQUERY_DATASET=medical_reports
# BIGQUERY_TABLE=reports
